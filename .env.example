# XRPL Network Configuration
XRPL_JSON_RPC_URL=https://s1.ripple.com:51234/

# Database Configuration
# Options: postgresql, sqlite
DATABASE_TYPE=postgresql
# For PostgreSQL, use DATABASE_URL from Replit environment
# For SQLite, use: DATABASE_URL=sqlite:///xrpl_indexer.db

# Indexer Scheduler Configuration
# Run indexer every X minutes
CRON_INTERVAL_MINUTES=5

# Transaction Filters (Optional)
# Leave empty to index all transactions

# Filter by transaction types (comma-separated)
# Examples: Payment,NFTokenMint,OfferCreate,TrustSet
FILTER_TRANSACTION_TYPES=

# Filter by addresses (comma-separated)
# Examples: rN7n7otQDd6FczFgLdlqtyMVrn3eBsePke,rPEPPER7kfTD9w2To4CQk6UCfuHM9c6GDY
FILTER_ADDRESSES=

# Filter by source tags (comma-separated integers)
# Examples: 123,456,789
FILTER_SOURCE_TAGS=
