# NODE url
XRPL_JSON_RPC_URL=https://s1.ripple.com:51234/

# Database Configuration
# Options: postgresql, sqlite
DATABASE_TYPE=postgresql
# For SQLite, use: DATABASE_URL=sqlite:///xrpl_indexer.db

# PostgreSQL individual credentials (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=xrpl_user
DB_PASSWORD=your_password_here
DB_NAME=xrpl_indexer

# Indexer Scheduler Configuration
CRON_INTERVAL_MINUTES=5

# Parallel Processing (Optional - Disabled by default)
# WARNING: Only enable if you have no rate limits and need to sync faster
# Set to "true" to enable parallel ledger processing
ENABLE_PARALLEL_PROCESSING=false
# Number of concurrent workers (default: 5)
# Higher values = faster processing but more API calls
PARALLEL_WORKERS=5

# Hub-and-Spoke Wallet Tracking
# Set this to the address of your central funding wallet.
# The indexer will automatically discover and track all wallets it activates.
# Leave empty to disable hub-and-spoke tracking.
CENTRAL_WALLET_ADDRESS=

# Transaction Filters (Optional)
# Leave empty to index all transactions

# Filter by transaction types (comma-separated)
# Examples: Payment,NFTokenMint,OfferCreate,TrustSet
FILTER_TRANSACTION_TYPES=

# Filter by addresses (comma-separated)
# Examples: rN7n7otQDd6FczFgLdlqtyMVrn3eBsePke,rPEPPER7kfTD9w2To4CQk6UCfuHM9c6GDY
FILTER_ADDRESSES=

# Filter by source tags (comma-separated integers)
# Examples: 123,456,789
FILTER_SOURCE_TAGS=
